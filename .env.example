# ── Nhost (required) ──────────────────────────────────────────
# Find these in your Nhost project dashboard (Project > Settings).
VITE_NHOST_SUBDOMAIN=your-subdomain
VITE_NHOST_REGION=your-region

# ── Owner (admin) ─────────────────────────────────────────────
# The email you sign in with to manage the billboard at /#admin.
VITE_OWNER_EMAIL=your-owner-email@example.com

# ── Resend (newsletter emails) ────────────────────────────────
# Server-side only (Netlify functions). Set in Netlify dashboard for prod,
# or in .env file for local `netlify dev`.
RESEND_API_KEY=your-resend-api-key
OWNER_EMAIL=your-owner-email@example.com
